{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "serena": {
      "type": "local",
      "command": ["uvx", "--from", "git+https://github.com/oraios/serena", "serena", "start-mcp-server" , "--context", "ide", "--project-from-cwd"],
      "enabled": true
    }
  },
  "provider": {
    "ollama": {
      "name": "Ollama (local)",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "kimi-k2.5:cloud": {
          "_launch": true,
          "limit": {
            "context": 262144,
            "output": 262144
          },
          "name": "kimi-k2.5:cloud"
        },
        "gemma4:latest": {
          "name": "gemma4:latest"
        },
        "gemma4:31b": {
          "name": "gemma4:31b"
        },
        "deepseek-r1:8b": {
          "name": "deepseek-r1:8b"
        },
        "qwen3:8b": {
          "name": "qwen3:8b"
        },
        "glm-4.7-flash:latest": {
          "name": "glm-4.7-flash:latest"
        },
        "llama3:latest": {
          "name": "llama3:latest"
        }
      }
    }
  }
}